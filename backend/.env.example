# Solo — Configuration

# DeepSeek API (chat IA)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ElevenLabs (voix IA)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# CinetPay (paiement Orange Money / MTN / Wave)
CINETPAY_API_KEY=your_cinetpay_api_key_here
CINETPAY_SITE_ID=your_cinetpay_site_id_here

# PostgreSQL (Render ou Supabase)
DATABASE_URL=postgresql://user:password@host:5432/solo

# JWT (authentification)
JWT_SECRET=change_this_to_random_64_chars_string
JWT_REFRESH_SECRET=change_this_to_another_random_string

# URL de base (pour les callbacks CinetPay)
BASE_URL=https://solo.africa

# Port serveur
PORT=3000
