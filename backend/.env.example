# Solo — Configuration

# DeepSeek API (chat IA)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ElevenLabs (voix IA)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# CinetPay (paiement Orange Money / MTN / Wave)
CINETPAY_API_KEY=your_cinetpay_api_key_here
CINETPAY_SITE_ID=your_cinetpay_site_id_here

# Fal.ai (génération d'images IA — RECOMMANDÉ, RealVis XL, selfies naturels)
# https://fal.ai/dashboard → API Keys → 3-8s par image, qualité pro
FALAI_API_KEY=your_falai_api_key_here

# Replicate (génération d'images IA — Juggernaut XL / RealVis, qualité premium)
# https://replicate.com/account/api-tokens
REPLICATE_API_KEY=your_replicate_api_key_here
# Modèle par défaut (change si besoin)
# REPLICATE_MODEL=adirik/juggernaut-xl-v9

# OpenRouter (modèle NSFW non censuré pour conversations explicites)
# https://openrouter.ai/keys — crée une clé, ajoute $5 de crédit
# Modèle : llama-3.1-euryale-70b (le meilleur pour NSFW en français)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# RunPod (génération d'images IA — RECOMMANDÉ, pas de censure NSFW)
# https://www.runpod.io/console/serverless — créer un endpoint SDXL
# Modèle : stable-diffusion-xl, nsfw_filter: false
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_ENDPOINT_ID=your_sdxl_endpoint_id_here

# Replicate (fallback si RunPod non configuré — censure les images NSFW)
# https://replicate.com/account/api-tokens
REPLICATE_API_KEY=your_replicate_api_key_here

# Hugging Face (fallback, gratuit jusqu'à 30k req/mois — censure NSFW)
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# PostgreSQL (Render ou Supabase)
DATABASE_URL=postgresql://user:password@host:5432/solo

# JWT (authentification)
JWT_SECRET=change_this_to_random_64_chars_string
JWT_REFRESH_SECRET=change_this_to_another_random_string

# URL de base (pour les callbacks CinetPay)
BASE_URL=https://solodesir.com

# PostHog (analytics, optionnel)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Port serveur
PORT=3000
